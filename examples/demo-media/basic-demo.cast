[5.300,"o","$ claw ship --intent 01HXDEMOINTENT0000000000 --revision-ref heads/demo --agent demo-agent --evidence smoke=pass:15 --evidence lint=pass:7\r\nShipped intent: 01HXDEMOINTENT0000000000\r\n  Capsule: clw_demo_capsule\r\n  Revision: clw_demo_revision\r\n"]
