[0.900,"o","$ claw intent create --title \"Add dark mode\" --goal \"Support theme toggling\"\r\nCreated intent: 01HXDEMOINTENT0000000000\r\n  Title: Add dark mode\r\n  Object: clw_demo_intent\r\n"]
