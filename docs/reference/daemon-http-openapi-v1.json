{
  "openapi": "3.0.3",
  "info": {
    "title": "Daemon HTTP API",
    "version": "v1"
  },
  "paths": {
    "/v1/health/live": {
      "get": {
        "responses": {
          "200": {
            "description": "Liveness status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/v1/health/ready": {
      "get": {
        "responses": {
          "200": {
            "description": "Readiness status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/v1/health/deps": {
      "get": {
        "responses": {
          "200": {
            "description": "Dependency health status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/v1/metrics": {
      "get": {
        "responses": {
          "200": {
            "description": "Metrics payload",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthEnvelope": {
        "type": "object",
        "required": [
          "code",
          "message",
          "request_id",
          "details"
        ],
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
